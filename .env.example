# Копіюйте в .env.local і заповніть значення. Не комітьте .env.local у репозиторій.

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=

# Cron (для Vercel Cron та захищених API)
CRON_SECRET=

# База даних (Neon / Postgres)
DATABASE_URL=

# KV / Redis (Vercel KV або REDIS_URL)
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# REDIS_URL=

# Facebook Page (пости дайджесту, мовчання, новин)
FACEBOOK_PAGE_ID=
FACEBOOK_PAGE_ACCESS_TOKEN=

# Google Analytics 4 (перегляди в Google-статистиці)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Публічний базовий URL сайту (впливає на canonical/metadataBase/sitemap/robots)
# Приклад: https://light-news.com.ua
NEXT_PUBLIC_SITE_URL=

# AI (опційно)
GROQ_API_KEY=
# Детектор маніпуляцій: аналіз об'єктивності новин (Google AI Studio → API key)
GEMINI_API_KEY=
